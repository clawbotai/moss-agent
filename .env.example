# Optional: store runtime data outside the repo.
# MOSS_DATA_DIR=/Users/you/Library/Application Support/moss-agent

# Optional: override CLI discovery.
# MOSS_CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex
# MOSS_CLAUDE_BIN=/opt/homebrew/bin/claude

# Optional: stuck detection timeout in milliseconds (default: 120000)
# MOSS_STUCK_TIMEOUT_MS=120000

# Note: better-sqlite3 requires native compilation.
# On macOS: xcode-select --install
# On Ubuntu/Debian: sudo apt-get install build-essential python3
# On Alpine: apk add python3 make g++
# On Windows: npm install --global windows-build-tools
